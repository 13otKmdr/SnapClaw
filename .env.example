# Environment variables for SnapClaw Backend and Mobile applications

# --- Backend Configuration ---

# JWT Secret Key: Used for signing JWT tokens for user authentication.
# MUST be a strong, random string. Generate with: ./generate-secrets.sh
JWT_SECRET_KEY=

# App Secret: Shared secret used by the mobile app for WebSocket authentication.
# MUST be a strong, random string. Generate with: ./generate-secrets.sh
APP_SECRET=

# Database Path: Path to the SQLite database file for session and authentication data.
# Default: voice_sessions.db (will be created in the backend directory)
# DB_PATH=voice_sessions.db

# CORS Origins: Comma-separated list of allowed origins for CORS (Cross-Origin Resource Sharing).
# For production, restrict this to your frontend domain(s).
# Default: http://localhost:3000,http://localhost:8000
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# OpenAI API Key: Required for OpenAI services (Whisper STT, TTS, GPT models).
# OPENAI_API_KEY=

# Agent Zero URL: Base URL for the Agent Zero instance.
# Default: http://localhost:50001 (for local development)
# AGENT_ZERO_URL=http://localhost:50001

# Agent Zero API Key: API key for authenticating with Agent Zero.
# AGENT_ZERO_API_KEY=

# TTS Voice: The voice to use for OpenAI Text-to-Speech.
# Options: alloy, echo, fable, onyx, nova, shimmer
# Default: onyx
# TTS_VOICE=onyx

# --- OpenRouter Configuration (Optional) ---
# Used for alternative LLM providers via OpenRouter.ai
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=z-ai/glm-5
# OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_MODE=auto
# OPENROUTER_RESPONSES_MODALITIES=text

# --- Z-AI Configuration (Optional) ---
# Used for Z-AI LLM and ASR services.
# ZAI_API_KEY=
# ZAI_MODEL=glm-5
# ZAI_ASR_MODEL=glm-asr-2512
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# --- Local Whisper Configuration (Optional) ---
# Used for local Speech-to-Text processing with faster-whisper.
# LOCAL_WHISPER_ENABLED=true
# LOCAL_WHISPER_MODEL=tiny.en
# LOCAL_WHISPER_DEVICE=cpu
# LOCAL_WHISPER_COMPUTE_TYPE=int8
# LOCAL_WHISPER_LANGUAGE=en
# LOCAL_WHISPER_BEAM_SIZE=1

# LLM Timeout: Timeout in seconds for LLM API calls.
# Default: 45
# LLM_TIMEOUT_SECONDS=45

# --- Mobile App Configuration (Expo Public Variables) ---

# API URL: Base URL for the SnapClaw backend API.
# For local development on physical devices, replace localhost with your backend machine's LAN IP.
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL: Base URL for the SnapClaw backend WebSocket.
# For local development on physical devices, replace localhost with your backend machine's LAN IP.
# Example: EXPO_PUBLIC_WS_URL=ws://192.168.1.100:8000
EXPO_PUBLIC_WS_URL=ws://localhost:8000

# Realtime Enabled: Set to true to enable realtime WebSocket voice processing.
# Default: false (uses REST text mode)
# EXPO_PUBLIC_REALTIME_ENABLED=true

# --- Other Configuration ---
# Telegram Bot Token (get from @BotFather)
# TELEGRAM_BOT_TOKEN=

# OpenClaw URL
# OPENCLAW_URL=http://localhost:8080

# Orchestration task polling
# TASK_POLL_INTERVAL_SECONDS=2
# TASK_MAX_POLL_ERRORS=5

# Database URL (optional - for persistent storage, e.g., PostgreSQL)
# DATABASE_URL=postgresql://user:pass@localhost/voice_interface

# Redis URL
# REDIS_URL=redis://localhost:6379/0
# TASK_STORE=memory
# TASK_REDIS_PREFIX=orchestrator

# Domain for SSL (your actual domain, used by Caddy in docker-compose)
# DOMAIN=voice.yourdomain.com
# EMAIL=your-email@example.com
