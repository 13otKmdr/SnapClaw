# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Agent Zero URL (internal Docker network or external)
AGENT_ZERO_URL=http://localhost:50001

# OpenClaw URL
OPENCLAW_URL=http://localhost:8080

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me

# Database URL (optional - for persistent storage)
DATABASE_URL=postgresql://user:pass@localhost/voice_interface

# Redis URL
REDIS_URL=redis://localhost:6379/0

# Domain for SSL (your actual domain)
DOMAIN=voice.yourdomain.com
EMAIL=your-email@example.com
