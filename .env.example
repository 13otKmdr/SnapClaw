# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Agent Zero URL (internal Docker network or external)
AGENT_ZERO_URL=http://localhost:50001
AGENT_ZERO_EXECUTOR=http
AGENT_ZERO_TIMEOUT_SECONDS=30
AGENT_ZERO_CREATE_PATH=/api/task
AGENT_ZERO_STATUS_PATH=/api/task/{task_id}
AGENT_ZERO_UPDATE_PATH=/api/task/{task_id}
AGENT_ZERO_CANCEL_PATH=/api/task/{task_id}
AGENT_ZERO_EXECUTE_FALLBACK_PATH=/api/execute
AGENT_ZERO_MOCK_DELAY_SECONDS=5

# OpenClaw URL
OPENCLAW_URL=http://localhost:8080

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me

# OpenAI Realtime API
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_VOICE=
REALTIME_ENABLE_SERVER_VAD=true
REALTIME_ASSISTANT_INSTRUCTIONS=

# Orchestration task polling
TASK_POLL_INTERVAL_SECONDS=2
TASK_MAX_POLL_ERRORS=5

# Database URL (optional - for persistent storage)
DATABASE_URL=postgresql://user:pass@localhost/voice_interface

# Redis URL
REDIS_URL=redis://localhost:6379/0
TASK_STORE=memory
TASK_REDIS_PREFIX=orchestrator

# Domain for SSL (your actual domain)
DOMAIN=voice.yourdomain.com
EMAIL=your-email@example.com
