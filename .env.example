# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Agent Zero URL (internal Docker network or external)
AGENT_ZERO_URL=http://agent-zero:80
AGENT_ZERO_EXECUTOR=http
AGENT_ZERO_TIMEOUT_SECONDS=30
AGENT_ZERO_CREATE_PATH=/api/task
AGENT_ZERO_STATUS_PATH=/api/task/{task_id}
AGENT_ZERO_UPDATE_PATH=/api/task/{task_id}
AGENT_ZERO_CANCEL_PATH=/api/task/{task_id}
AGENT_ZERO_EXECUTE_FALLBACK_PATH=/api/execute
AGENT_ZERO_MOCK_DELAY_SECONDS=5

# OpenClaw URL
OPENCLAW_URL=http://localhost:8080

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me

# OpenAI Realtime API
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_VOICE=
REALTIME_ENABLE_SERVER_VAD=true
REALTIME_ASSISTANT_INSTRUCTIONS=

# OpenRouter LLM API (recommended for full chat responses)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-5
# Text-route fallback model when OPENROUTER_MODEL is audio/realtime-only (e.g. openai/gpt-audio-mini)
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter API mode: auto|chat|responses
OPENROUTER_API_MODE=auto
# Responses API modalities CSV, e.g. "text" or "text,audio"
OPENROUTER_RESPONSES_MODALITIES=text

# Z.AI model APIs (optional; if omitted, local Whisper fallback is used for STT)
ZAI_API_KEY=
ZAI_MODEL=glm-5
ZAI_ASR_MODEL=glm-asr-2512
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Local Whisper fallback (used for /api/voice/transcribe when ZAI_API_KEY is not set)
LOCAL_WHISPER_ENABLED=true
LOCAL_WHISPER_MODEL=tiny.en
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8
LOCAL_WHISPER_LANGUAGE=en
LOCAL_WHISPER_BEAM_SIZE=1

# Orchestration task polling
TASK_POLL_INTERVAL_SECONDS=2
TASK_MAX_POLL_ERRORS=5

# Database URL (optional - for persistent storage)
DATABASE_URL=postgresql://user:pass@localhost/voice_interface

# Redis URL
REDIS_URL=redis://localhost:6379/0
TASK_STORE=memory
TASK_REDIS_PREFIX=orchestrator

# Domain for SSL (your actual domain)
DOMAIN=voice.yourdomain.com
EMAIL=your-email@example.com

# Mobile client env (set these in mobile/.env or pass via Expo config)
# EXPO_PUBLIC_REALTIME_ENABLED must be "true" for the WebSocket path to activate.
# Without it, all messages fall back to the REST /api/voice/process endpoint.
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_WS_URL=ws://localhost:8000
EXPO_PUBLIC_REALTIME_ENABLED=true
